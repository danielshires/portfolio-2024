---
// Client router
import '../styles/global.css'
import '../styles/fonts.css'
import Navigation from '../components/layout/navigation/Navigation.astro'
import Footer from '../components/layout/Footer.astro'
import Head from './Head.astro'
import SEO from '../components/common/SEO.astro'
import { mergeGlobalJsonLd } from '../lib/seo/merge-global-jsonld'
import { navLinkActiveClass, navLinkInactiveClass } from '../components/ui/text/styles'

interface Props {
  pageTitle: string
  pageDescription: string
  pageImage?: string
  pageImageAlt?: string
  pageType?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
  robots?: string
  jsonLd?: unknown
  children?: any
}

const {
  pageTitle,
  pageDescription,
  pageImage,
  pageImageAlt,
  pageType = 'website',
  publishedTime,
  modifiedTime,
  robots,
  jsonLd,
} = Astro.props

const mergedJsonLd = mergeGlobalJsonLd(jsonLd)
---

<!doctype html>
<html lang='en' class='text-base'>
  <head>
  <!-- iOS Safari Status Bar Style -->
  <meta name='apple-mobile-web-app-status-bar-style' content='default' />
  <meta name='apple-mobile-web-app-capable' content='yes' />

  <!-- Additional iOS Safari Integration -->
  <meta name='apple-mobile-web-app-title' content={pageTitle} />
  <meta name='format-detection' content='telephone=no' />
  <script is:inline>
    // ✅ SINGLE THEME INITIALIZATION - Prevent flash on initial load
    ;(function () {
      try {
        var stored = localStorage.getItem('theme')
        var theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light'
        // Apply theme immediately
        if (theme === 'dark') {
          document.documentElement.classList.add('dark')
        } else {
          document.documentElement.classList.remove('dark')
        }
        // Dark: solid canvas on `html`. Light: CSS paints gradient (no inline fill).
        if (theme === 'dark') {
          document.documentElement.style.backgroundColor = 'rgb(9, 9, 11)'
          document.body.style.removeProperty('background-color')
        } else {
          document.documentElement.style.removeProperty('background-color')
          document.body.style.removeProperty('background-color')
        }
      } catch (e) {}
    })()
  </script>
  <script
    is:inline
    set:html={`window.__portfolioNavLinkActiveClass=${JSON.stringify(navLinkActiveClass)};window.__portfolioNavLinkInactiveClass=${JSON.stringify(navLinkInactiveClass)};`}
  />
  <script is:inline>
    // After Swup navigations (same signals @swup/astro emits for Astro islands)
    document.addEventListener('astro:page-load', function() {
      document.dispatchEvent(new CustomEvent('portfolio:route-change'))
    })

    document.addEventListener('swup:content:replace', function (e) {
      var visit = e.detail && e.detail.visit
      if (!visit || visit.history.popstate || visit.to.hash) return
      if (visit.scroll && visit.scroll.reset === false) return
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' })
    })

    // Only remove focus after transitions complete to avoid disrupting animations
    document.addEventListener('astro:page-load', function() {
      const mainElement = document.querySelector('#main-content')
      if (mainElement && mainElement === document.activeElement) {
        mainElement.blur()
        mainElement.style.outline = 'none'
        mainElement.style.boxShadow = 'none'
        mainElement.style.border = 'none'
      }
    })

    // Chrome-specific fix: Prevent focus entirely on both body and main
    if (!window.chromeFocusFixInitialized) {
      window.chromeFocusFixInitialized = true

      const chromeUserAgent = /Chrome/.test(navigator.userAgent)
      if (chromeUserAgent) {
        function removeFocusStyles() {
          const bodyElement = document.body
          const mainElement = document.querySelector('#main-content')

          // Remove focus from body
          if (bodyElement) {
            bodyElement.style.setProperty('outline', 'none', 'important')
            bodyElement.style.setProperty('outline-color', 'transparent', 'important')
            bodyElement.style.setProperty('outline-style', 'none', 'important')
            bodyElement.style.setProperty('outline-width', '0', 'important')
            bodyElement.style.setProperty('box-shadow', 'none', 'important')
            bodyElement.blur()
          }

          // Remove focus from main
          if (mainElement) {
            mainElement.style.setProperty('outline', 'none', 'important')
            mainElement.style.setProperty('outline-color', 'transparent', 'important')
            mainElement.style.setProperty('outline-style', 'none', 'important')
            mainElement.style.setProperty('outline-width', '0', 'important')
            mainElement.blur()
          }
        }

        // Only apply focus removal after transitions complete, not during
        document.addEventListener('astro:page-load', function() {
          setTimeout(removeFocusStyles, 100)
        })
      }
    }

    if (!window.navigationHandlerInitialized) {
      window.navigationHandlerInitialized = true

      function updateNavigationActiveState() {
        const currentPath = window.location.pathname.slice(1)
        const navLinks = document.querySelectorAll('[data-nav-path]')

        if (navLinks.length === 0) {
          return false
        }

        var activeClass = window.__portfolioNavLinkActiveClass
        var inactiveClass = window.__portfolioNavLinkInactiveClass
        if (typeof activeClass !== 'string' || typeof inactiveClass !== 'string') {
          return false
        }

        navLinks.forEach((link) => {
          const path = link.getAttribute('data-nav-path')
          const isActive =
            path === ''
              ? currentPath === ''
              : currentPath.startsWith(path) && path !== ''

          link.className = isActive ? activeClass : inactiveClass
        })

        return true
      }

      function scheduleNavigationUpdate() {
        if (updateNavigationActiveState()) {
          return
        }

        setTimeout(() => {
          if (updateNavigationActiveState()) {
            return
          }

          setTimeout(() => {
            updateNavigationActiveState()
          }, 100)
        }, 10)
      }

      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => updateNavigationActiveState(), 0)
      })

      document.addEventListener('astro:after-swap', scheduleNavigationUpdate)
      document.addEventListener('astro:page-load', scheduleNavigationUpdate)

      window.addEventListener('popstate', scheduleNavigationUpdate)

      let lastUrl = window.location.href
      setInterval(() => {
        if (window.location.href !== lastUrl) {
          lastUrl = window.location.href
          scheduleNavigationUpdate()
        }
      }, 100)
    }
  </script>
  <script is:inline>
    // ✅ CURRENT WORKING THEME SYSTEM - Approach 4: Isolated theme manager
    if (!window.simpleThemeManagerInitialized) {
      window.simpleThemeManagerInitialized = true

      // Effective theme = explicit choice (localStorage) OR system preference (never persist system automatically).
      function getStoredThemeOverride() {
        var raw = localStorage.getItem('theme')
        return raw === 'light' || raw === 'dark' ? raw : null
      }

      function resolveEffectiveTheme() {
        var o = getStoredThemeOverride()
        if (o) return o
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      }

      function applyThemeDom(theme) {
        window.currentThemeState = theme

        if (theme === 'dark') {
          document.documentElement.classList.add('dark')
        } else {
          document.documentElement.classList.remove('dark')
        }

        var bgColor = theme === 'dark' ? 'rgb(9, 9, 11)' : 'rgb(250, 250, 250)'
        var textColor = theme === 'dark' ? 'rgb(250, 250, 250)' : 'rgb(9, 9, 11)'
        document.documentElement.style.setProperty('--background-color', bgColor)
        document.documentElement.style.setProperty('--text-color', textColor)

        if (theme === 'dark') {
          document.documentElement.style.backgroundColor = bgColor
          document.body.style.removeProperty('background-color')
        } else {
          document.documentElement.style.removeProperty('background-color')
          document.body.style.removeProperty('background-color')
        }

        document.documentElement.classList.remove('bg-zinc-50', 'bg-zinc-100', 'bg-zinc-900', 'bg-zinc-950', 'bg-background-light', 'bg-background-dark')
        document.body.classList.remove('bg-zinc-50', 'bg-zinc-100', 'bg-zinc-900', 'bg-zinc-950', 'bg-background-light', 'bg-background-dark')

        var themeColorMeta = document.querySelector('meta[name="theme-color"]:not([media])')
        if (!themeColorMeta) {
          try {
            themeColorMeta = document.createElement('meta')
            themeColorMeta.name = 'theme-color'
            document.head.appendChild(themeColorMeta)
          } catch (e) {
            console.warn('Failed to create theme-color meta tag:', e)
            return
          }
        }
        if (themeColorMeta) {
          themeColorMeta.content = theme === 'dark' ? '#09090b' : '#fcfbfb'
        }

        var buttons = document.querySelectorAll('[data-theme-toggle]')
        buttons.forEach(function(button) {
          var sunIcon = button.querySelector('[data-sun-icon]')
          var moonIcon = button.querySelector('[data-moon-icon]')

          if (sunIcon && moonIcon) {
            if (theme === 'dark') {
              sunIcon.classList.remove('hidden')
              moonIcon.classList.add('hidden')
              button.setAttribute('aria-label', 'Switch to light mode')
            } else {
              sunIcon.classList.add('hidden')
              moonIcon.classList.remove('hidden')
              button.setAttribute('aria-label', 'Switch to dark mode')
            }
          }
        })
      }

      function refreshTheme() {
        applyThemeDom(resolveEffectiveTheme())
      }

      function toggleTheme() {
        var eff = resolveEffectiveTheme()
        var next = eff === 'dark' ? 'light' : 'dark'
        localStorage.setItem('theme', next)
        applyThemeDom(next)
      }

      document.addEventListener('click', function(event) {
        var button = event.target.closest('[data-theme-toggle]')
        if (button) {
          event.preventDefault()
          event.stopPropagation()
          toggleTheme()
        }
      })

      refreshTheme()

      document.addEventListener('astro:after-swap', refreshTheme)

      document.addEventListener('astro:page-load', refreshTheme)

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
        if (getStoredThemeOverride()) return
        refreshTheme()
      })

      window.addEventListener('storage', function(e) {
        if (e.key !== 'theme') return
        refreshTheme()
      })
    }

    // ✨ ELEMENT ANIMATION SYSTEM - Re-trigger animations after Swup navigations
    if (!window.elementAnimationsInitialized) {
      window.elementAnimationsInitialized = true

      function triggerElementAnimations() {
        var animatedElements = document.querySelectorAll('[class*="animate-fade-in"]')
        animatedElements.forEach(function(element) {
          element.style.animation = 'none'
          element.offsetHeight // Force reflow
          element.style.animation = null
        })
      }

      document.addEventListener('astro:after-swap', function() {
        setTimeout(triggerElementAnimations, 50)
      })

      document.addEventListener('astro:page-load', function() {
        setTimeout(triggerElementAnimations, 50)
      })

      // Also trigger on initial page load
      document.addEventListener('DOMContentLoaded', triggerElementAnimations)
      window.addEventListener('load', triggerElementAnimations)
    }

  </script>
  <Head />
  <SEO
    title={pageTitle}
    description={pageDescription}
    image={pageImage}
    imageAlt={pageImageAlt}
    type={pageType}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    robots={robots}
    jsonLd={mergedJsonLd}
  />
  <slot name='head' />
  <style is:global>
  /* Ensure consistent background during transitions */

  body {
    transition: background-color 0.2s ease-out;
  }

  /* Targeted transitions for theme-sensitive elements only */
  .theme-transition {
    transition:
      background-color 0.2s ease-out,
      color 0.2s ease-out,
      border-color 0.2s ease-out;
  }

  /* Prevent any blue focus rings on main container */
  #main-content:focus,
  #main-content:focus-visible,
  #main-content:focus-within {
    outline: none !important;
    box-shadow: none !important;
    --tw-ring-shadow: none !important;
    --tw-ring-offset-shadow: none !important;
  }

  /* Chrome-specific fix for blue focus lines */
  body, main {
    -webkit-tap-highlight-color: transparent !important;
    -webkit-focus-ring-color: transparent !important;
    outline: none !important;
  }

  /* Override focus styles on body element */
  body:focus,
  body:focus-visible,
  body:focus-within {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }

  /* Force Chrome to never show focus rings on body and main */
  @supports (-webkit-appearance: none) {
    body, #main-content {
      outline: none !important;
      outline-offset: 0 !important;
      outline-color: transparent !important;
      outline-style: none !important;
      outline-width: 0 !important;
    }

    body:focus, #main-content:focus {
      outline: none !important;
      outline-offset: 0 !important;
      outline-color: transparent !important;
      outline-style: none !important;
      outline-width: 0 !important;
    }
  }

  #main-content {
    outline: none !important;
    -webkit-appearance: none !important;
    -moz-appearance: none !important;
    pointer-events: auto !important;
  }

  #main-content:focus,
  #main-content:active,
  #main-content:focus-visible {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }

  /* Entry animation for elements using .animate-fade-in-delay-1 (e.g. project detail, footer CTA) */
  .animate-fade-in-delay-1 {
    opacity: 0;
    transform: translateY(30px);
    animation: elementFadeIn 0.1s ease-out 0.1s forwards;
  }

  @keyframes elementFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Button hover optimizations */
  button, a[role="button"], .btn {
    will-change: transform;
  }

  /* Theme toggle specific optimizations */
  [data-theme-toggle] {
    will-change: transform;
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-delay-1 {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }

    button, a[role="button"], .btn, [data-theme-toggle] {
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease !important;
    }

    button:hover, a[role="button"]:hover, .btn:hover, [data-theme-toggle]:hover {
      transform: none !important;
      animation: none !important;
    }

    [data-theme-toggle] svg {
      transition: none !important;
      transform: none !important;
    }
  }

  .skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .skip-link:focus {
    position: fixed;
    top: 1rem;
    left: 1rem;
    width: auto;
    height: auto;
    margin: 0;
    padding: 0.5rem 1rem;
    overflow: visible;
    clip: auto;
    white-space: normal;
    z-index: 100;
    border-radius: 0.375rem;
    border: 1px solid rgb(228 228 231);
    background-color: rgb(250 250 250);
    color: rgb(9 9 11);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  html.dark .skip-link:focus {
    border-color: rgb(63 63 70);
    background-color: rgb(24 24 27);
    color: rgb(250 250 250);
  }
</style>
  </head>
  <body
    class='text-text-light dark:text-text-dark antialiased min-h-dvh flex flex-col'
    tabindex="-1">
    <a href='#main-content' class='skip-link theme-transition'>Skip to main content</a>
    <Navigation />
    <main id='main-content' class='container mx-auto px-8 lg:px-16 flex-1 w-full' tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
