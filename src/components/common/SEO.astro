---
interface Props {
  title: string
  description: string
  image?: string
  imageAlt?: string
  type?: 'website' | 'article'
  twitterHandle?: string
  twitterCard?: 'summary' | 'summary_large_image'
  googleTagId?: string
  robots?: string
  publishedTime?: string
  modifiedTime?: string
  locale?: string
  jsonLd?: unknown
}

const {
  title,
  description,
  image = '/images/jpg/background.webp',
  imageAlt,
  type = 'website',
  twitterHandle = '@danielshires',
  twitterCard = 'summary_large_image',
  googleTagId = import.meta.env.PUBLIC_GA_ID,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  publishedTime,
  modifiedTime,
  locale = 'en_AU',
  jsonLd,
} = Astro.props

const siteUrl = Astro.site || 'https://danielshires.com'
const canonicalURL = new URL(Astro.url.pathname, siteUrl)
const imageURL = new URL(image, siteUrl)

const jsonLdBlocks: unknown[] = Array.isArray(jsonLd)
  ? jsonLd
  : typeof jsonLd !== 'undefined' && jsonLd !== null
    ? [jsonLd]
    : []

const jsonLdHtml = jsonLdBlocks
  .map((block) => {
    try {
      return JSON.stringify(block)
    } catch {
      return ''
    }
  })
  .filter(Boolean)
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name='title' content={title} />
<meta name='description' content={description} />
<meta name='robots' content={robots} />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={type} />
<meta property='og:url' content={canonicalURL} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={imageURL} />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
{imageAlt && <meta property='og:image:alt' content={imageAlt} />}
<meta property='og:site_name' content='Daniel Shires - Dan Portfolio' />
<meta property='og:locale' content={locale} />

{type === 'article' && publishedTime && <meta property='article:published_time' content={publishedTime} />}
{type === 'article' && modifiedTime && <meta property='article:modified_time' content={modifiedTime} />}

<!-- Twitter -->
<meta name='twitter:card' content={twitterCard} />
<meta name='twitter:url' content={canonicalURL} />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={imageURL} />
<meta name='twitter:creator' content={twitterHandle} />
<meta name='twitter:site' content={twitterHandle} />

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Additional Meta Tags -->
<meta name='color-scheme' content='light dark' />
<meta name='theme-color' content='#ffffff' media='(prefers-color-scheme: light)' />
<meta name='theme-color' content='#09090b' media='(prefers-color-scheme: dark)' />

{jsonLdHtml.map((serialized) => (
  <script is:inline type='application/ld+json' set:html={serialized} />
))}

{googleTagId && (
  <>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleTagId}`}></script>
    <script is:inline set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${googleTagId}');
    `}></script>
  </>
)}
