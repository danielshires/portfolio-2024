---
/**
 * Journal footer links: curated `relatedPosts` when present; otherwise the next-older post.
 * Section label is “Related reading” when multiple links, “Read next” for a single suggestion.
 */

import Text from '../../ui/text/Text.astro'
import { linkFocusRingClass, textLinkClass } from '../../ui/text/styles'

export interface ReadNextPost {
  _id: string
  title: string
  slug?: { current: string }
}

interface Props {
  posts: readonly ReadNextPost[]
}

const { posts } = Astro.props

const items = posts.filter((p) => p?.slug?.current)
const sectionHeading = items.length > 1 ? 'Related reading' : 'Read next'
---

{
  items.length > 0 && (
    <section
      class='mt-16 pt-12 border-t border-zinc-200 dark:border-zinc-800 w-full max-w-[65ch] mx-auto'
      aria-labelledby='read-next-heading'>
      <Text variant='overline' color='muted' class='mb-8' id='read-next-heading'>
        {sectionHeading}
      </Text>
      <ul class='space-y-4 list-none p-0 m-0'>
        {items.map((p) => (
          <li>
            <a
              href={`/writing/${p.slug!.current}`}
              class={`block ${textLinkClass} ${linkFocusRingClass}`}
              data-swup-preload>
              <Text variant='h4' weight='medium' color='default'>
                {p.title}
              </Text>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
