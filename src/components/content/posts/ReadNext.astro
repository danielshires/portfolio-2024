---
/**
 * Minimal “Read next” list (title-only links).
 * Uses Sanity `relatedPosts` when set; otherwise `getPostBySlug` supplies recent posts.
 */

import Text from '../../ui/text/Text.astro'

export interface ReadNextPost {
  _id: string
  title: string
  slug?: { current: string }
}

interface Props {
  posts: readonly ReadNextPost[]
}

const { posts } = Astro.props

const items = posts.filter((p) => p?.slug?.current)
---

{
  items.length > 0 && (
    <section
      class='mt-16 pt-12 border-t border-zinc-200 dark:border-zinc-800 max-w-[75ch] mx-auto px-4 sm:px-0'
      aria-labelledby='read-next-heading'>
      <div class='w-10 h-0.5 rounded-full bg-amber-500 mb-5' aria-hidden='true' />
      <Text variant='overline' color='muted' class='mb-8' id='read-next-heading'>
        Read next
      </Text>
      <ul class='space-y-4 list-none p-0 m-0'>
        {items.map((p) => (
          <li>
            <a
              href={`/journal/${p.slug!.current}`}
              class='block rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-zinc-900 dark:focus-visible:ring-zinc-100 dark:focus-visible:ring-offset-zinc-950'
              data-swup-preload>
              <Text variant='h4' weight='medium' color='default' class='hover:underline underline-offset-4 decoration-zinc-400 dark:decoration-zinc-500'>
                {p.title}
              </Text>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
