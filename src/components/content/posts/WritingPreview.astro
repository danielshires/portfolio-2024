---
import {
  contentSectionHeadingLinkClass,
  linkListMutedContinuationClass,
  linkListParagraphClass,
  linkListRowAnchorPlainClass,
  linkListStrongTitleClass,
  sectionYearLabelClass,
  stackBelowHeroClass,
} from '../../ui/text/styles'
import type { Post } from '../../../lib/sanity'

interface Props {
  posts: readonly Post[]
  /** Secondary line (excerpt/description). Off on the homepage for a title-only list. */
  showSubtitle?: boolean
}

const { posts, showSubtitle = false } = Astro.props
const preview = posts.slice(0, 8)
---

{
  preview.length > 0 && (
    <section class:list={[stackBelowHeroClass]} aria-label='Writing'>
      <h2 class={sectionYearLabelClass}>
        <a href='/journal' class={contentSectionHeadingLinkClass}>Writing →</a>
      </h2>
      <div class='flex flex-col'>
        {preview.map((post) => {
          const href = `/journal/${post.slug?.current || post._id}`
          const lineDescription = post.excerpt || post.description || ''
          return (
            <a
              href={href}
              class={linkListRowAnchorPlainClass}
              aria-label={`Read ${post.title}`}
              data-swup-preload>
              <p class={linkListParagraphClass}>
                <span class={linkListStrongTitleClass}>{post.title}</span>
                {showSubtitle && lineDescription ? (
                  <>
                    {' '}
                    <span class={linkListMutedContinuationClass}>
                      {lineDescription}
                    </span>
                  </>
                ) : null}
              </p>
            </a>
          )
        })}
      </div>
    </section>
  )
}
