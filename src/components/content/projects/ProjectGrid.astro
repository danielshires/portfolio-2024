---
import ProjectCard from './ProjectCard.astro'
import { urlFor, projectListHref, isExternalProject } from '../../../lib/sanity'
import type { Project } from '../../../lib/sanity'
import Text from '../../ui/text/Text.astro'

interface Props {
  projects: Project[]
  variant?: 'card' | 'text'
}

const { projects, variant = 'card' } = Astro.props

// Transform Sanity projects to match ProjectCard interface
const transformedProjects = projects.map((project) => ({
  projectImage: {
    src: project.heroImage
      ? urlFor(project.heroImage)
          .width(800)
          .height(600)
          .quality(85) // Standard quality for project thumbnails
          .auto('format')
          .fit('max')
          .url()
      : '/images/jpg/background.webp',
    alt: project.title + ' project showcase',
    width: 800,
    height: 600,
  },
  title: project.client || project.tags?.[0] || 'Project',
  heading: project.subtitle,
  description: project.subtitle || 'View project details',
  external: isExternalProject(project),
  projectUrl: projectListHref(project),
}))
---

<section
  class:list={[
    variant === 'text'
      ? 'space-y-6 mt-16 max-w-[100vw]'
      : 'grid grid-cols-1 md:grid-cols-6 lg:grid-cols-3 gap-8 max-w-[100vw] mt-16',
  ]}>
  <div class:list={[variant === 'text' ? 'flex items-baseline justify-between gap-4' : 'col-span-full']}>
    {
      variant === 'text' ? (
        <a href='/projects' class='inline-block group'>
          <Text variant='overline' class='underline-offset-4 group-hover:underline'>
            Projects →
          </Text>
        </a>
      ) : (
        <Text variant='overline'>Recent projects</Text>
      )
    }
  </div>
  <div class:list={[variant === 'text' ? 'col-span-full space-y-1' : 'contents']}>
    {
      transformedProjects.map((project) =>
        variant === 'text' ? (
          <ProjectCard variant='text' {...project} />
        ) : (
          <div>
            <ProjectCard {...project} />
          </div>
        )
      )
    }
  </div>
</section>
