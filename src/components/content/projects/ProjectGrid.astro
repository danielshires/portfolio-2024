---
import ProjectCard from './ProjectCard.astro'
import { urlFor, projectListHref, isExternalProject } from '../../../lib/sanity'
import type { Project } from '../../../lib/sanity'
import Text from '../../ui/text/Text.astro'
import {
  contentSectionHeadingLinkClass,
  sectionYearLabelClass,
  stackBelowHeroClass,
} from '../../ui/text/styles'

interface Props {
  projects: Project[]
  variant?: 'card' | 'text'
  /** When `variant` is `text`, show project subtitle after the title (default true). */
  showSubtitle?: boolean
}

const { projects, variant = 'card', showSubtitle = true } = Astro.props

// Transform Sanity projects to match ProjectCard interface.
// Text variant (homepage list) uses project name + subtitle.
// Card variant keeps the existing client-as-headline layout.
const transformedProjects = projects.map((project) => {
  const isText = variant === 'text'
  const headline = isText
    ? project.title
    : project.client || project.tags?.[0] || project.title
  const sub = project.subtitle

  return {
    projectImage: {
      src: project.heroImage
        ? urlFor(project.heroImage)
            .width(800)
            .height(600)
            .quality(85)
            .auto('format')
            .fit('max')
            .url()
        : '/images/jpg/background.webp',
      alt: project.title + ' project showcase',
      width: 800,
      height: 600,
    },
    title: headline,
    heading: sub,
    description: sub,
    external: isExternalProject(project),
    projectUrl: projectListHref(project),
  }
})
---

<section
  class:list={[
    variant === 'text'
      ? ['flex', 'flex-col', stackBelowHeroClass, 'max-w-[100vw]']
      : ['grid', 'grid-cols-1', 'md:grid-cols-6', 'lg:grid-cols-3', 'gap-8', 'max-w-[100vw]', stackBelowHeroClass],
  ]}>
  {
    variant === 'text' ? (
      <h2 class={sectionYearLabelClass}>
        <a href='/projects' class={contentSectionHeadingLinkClass}>
          Projects →
        </a>
      </h2>
    ) : (
      <div class:list={['col-span-full']}>
        <Text variant='overline'>Recent projects</Text>
      </div>
    )
  }
  <div class:list={[variant === 'text' ? 'col-span-full flex flex-col' : 'contents']}>
    {
      transformedProjects.map((project) =>
        variant === 'text' ? (
          <ProjectCard variant='text' showSubtitle={showSubtitle} {...project} />
        ) : (
          <div>
            <ProjectCard {...project} />
          </div>
        )
      )
    }
  </div>
</section>
