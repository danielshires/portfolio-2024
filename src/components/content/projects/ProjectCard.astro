---
import Text from '../../ui/text/Text.astro'
import {
  linkListMutedContinuationClass,
  linkListParagraphClass,
  linkListRowAnchorClass,
  linkListStrongTitleClass,
} from '../../ui/text/styles'
import ExternalLinkGlyph from '../../ui/icons/ExternalLinkGlyph.astro'

interface Props {
  variant?: 'card' | 'text'
  /** When `variant` is `text`, show subtitle line (default true). */
  showSubtitle?: boolean
  /** When true: opens in new tab, no client navigation, shows external-link glyph (react-icons `HiOutlineExternalLink` stroke). */
  external?: boolean
  projectImage: {
    src: string
    alt: string
    width: number
    height: number
  }
  title: string
  heading?: string
  description?: string
  projectUrl: string
}

const {
  variant = 'card',
  external = false,
  projectImage,
  title,
  heading,
  projectUrl,
  showSubtitle = true,
} = Astro.props
const lineDescription = heading || Astro.props.description || ''
const linkLabel = external ? `${title} (opens in new tab)` : `View ${title} project`
---

{
  variant === 'text' ? (
    <div class='col-span-full'>
      <a
        href={projectUrl}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
        class={linkListRowAnchorClass}
        aria-label={linkLabel}
        data-swup-preload={external ? undefined : true}>
        <p class={linkListParagraphClass}>
          <span class={linkListStrongTitleClass}>{title}</span>
          {showSubtitle && lineDescription ? (
            <>
              {' '}
              <span class={linkListMutedContinuationClass}>
                {lineDescription}
              </span>
            </>
          ) : null}
          {external && (
            <>
              {' '}
              <ExternalLinkGlyph class='w-[0.85em] h-[0.85em] relative -top-[0.05em] align-middle text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-200 transition-colors duration-200' />
            </>
          )}
        </p>
      </a>
    </div>
  ) : (
    <div class='col-span-1 md:col-span-3 lg:col-span-1 p-1'>
      <a
        href={projectUrl}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
        class='group block relative overflow-hidden transition-colors duration-300 rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-black dark:focus-visible:ring-white cursor-pointer'
        aria-label={linkLabel}
        data-swup-preload={external ? undefined : true}>
        <div class='w-full aspect-[3/2] overflow-hidden rounded-xl'>
          <img
            src={projectImage.src}
            alt={projectImage.alt}
            width={projectImage.width}
            height={projectImage.height}
            class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 group-focus:scale-100'
            loading='eager'
            decoding='async'
          />
        </div>
        <div class='pt-2'>
          <div class:list={['mt-4 flex items-baseline gap-1.5 flex-wrap']}>
            <Text variant='h5' color='default' class='group-hover:underline underline-offset-4 decoration-zinc-400 decoration-1 dark:decoration-zinc-500 group-hover:decoration-zinc-600 dark:group-hover:decoration-zinc-300 transition-colors'>
              {title}
            </Text>
            {
              external && (
                <ExternalLinkGlyph class='w-4 h-4 shrink-0 self-center -translate-y-px text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-200 transition-colors duration-200' />
              )
            }
          </div>
          {heading && (
            <Text variant='body' color='muted' class='mt-1'>
              {heading}
            </Text>
          )}
        </div>
      </a>
    </div>
  )
}
