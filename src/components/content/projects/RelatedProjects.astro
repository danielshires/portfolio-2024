---
import { urlFor, projectListHref, isExternalProject } from '../../../lib/sanity'
import type { Project } from '../../../lib/sanity'
import Text from '../../ui/text/Text.astro'
import ProjectCard from './ProjectCard.astro'
import { sectionLabelTypographyClass } from '../../ui/text/styles'

interface Props {
  projects: Project[]
}

const { projects } = Astro.props

// Transform Sanity projects to match ProjectCard interface
const transformedProjects = projects.map((project) => ({
  projectImage: {
    src: project.heroImage
      ? urlFor(project.heroImage)
          .width(800)
          .height(600)
          .quality(85) // Standard quality for related project thumbnails
          .auto('format')
          .fit('max')
          .url()
      : '/images/jpg/background.webp',
    alt: project.title + ' project showcase',
    width: 800,
    height: 600,
  },
  title: project.client || project.tags?.[0] || 'Project',
  heading: project.subtitle,
  description: project.subtitle || 'View project details',
  external: isExternalProject(project),
  projectUrl: projectListHref(project),
}))
---

<section class='not-prose space-y-8 text-left' aria-labelledby='related-projects-heading'>
  <header>
    <!-- Plain <p> + shared label utilities (same as Thinking out loud “Recent / Earlier”) so prose/hidden overrides can’t flatten to body text. -->
    <p id='related-projects-heading' class:list={[sectionLabelTypographyClass, 'mb-3']}>
      Related projects
    </p>
    <Text variant='body' color='muted'>Explore more of my work</Text>
  </header>

  <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
    {transformedProjects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>
