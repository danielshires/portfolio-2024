---
import Text from '../../ui/text/Text.astro'

interface Props {
  value: string
  label: string
}

const { value, label } = Astro.props as Props
---

<div class='flex flex-col items-start md:items-start'>
  <Text variant='h4' class='font-fragment'>
    {value}
  </Text>
  <Text variant='caption' color='muted'>
    {label}
  </Text>
</div>
