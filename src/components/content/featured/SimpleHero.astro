---
import Text from '../../ui/text/Text.astro'
import { simpleHeroHeadingStackClass, simpleHeroSectionClass } from '../../ui/text/styles'

interface Props {
  introText: {
    first: string
    second: string
  }
}

const { introText } = Astro.props
---

<section class={simpleHeroSectionClass} aria-label='Hero Section'>
  <div class={simpleHeroHeadingStackClass}>
    <Text variant='h1'>{introText.first}</Text>
    <Text variant='lead'>{introText.second}</Text>
  </div>
</section>
