---
import Text from '../../ui/text/Text.astro'

interface Props {
  name: string
  intro: string
  avatar?: string
  subtitle?: string
}

const { name, intro, avatar, subtitle } = Astro.props
const showHeader = Boolean(name || subtitle)
const marginTopLead = showHeader ? (subtitle ? 'mt-10 md:mt-14' : 'mt-6 md:mt-10') : 'mt-0'
---

<section
  id='intro'
  class='flex flex-col items-start mt-44 md:mt-52 lg:mt-60'
  aria-label='Introduction'>
  {
    avatar && (
      <img
        src={avatar}
        alt={name ? `${name} avatar` : 'Avatar'}
        width='80'
        height='80'
        decoding='async'
        loading='eager'
        class='mb-10 md:mb-12 block size-20 rounded-full object-cover'
      />
    )
  }
  {
    showHeader && (
      <header class='flex flex-col items-start gap-1'>
        {
          name && (
            <p class='text-lg font-bold leading-snug text-zinc-900 dark:text-zinc-100 md:text-xl'>
              {name}
            </p>
          )
        }
        <!-- {subtitle && (
          <Text variant='body' size='sm' weight='normal' class='leading-snug'>
            {subtitle}
          </Text>
        )} -->
      </header>
    )
  }
  <h1
    class:list={[
      'max-w-4xl text-left font-normal text-zinc-900 dark:text-zinc-100',
      'xl:leading-normal',
      'text-xl sm:text-2xl md:text-3xl lg:text-4xl',
      'mt-4',
    ]}>
    {intro}
  </h1>
</section>
