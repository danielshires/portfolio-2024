---
interface Props {
  name: string
  intro: string
  avatar?: string
  subtitle?: string
}

const { name, intro, avatar } = Astro.props
---

<section
  id='intro'
  class='flex flex-col items-start mt-44 md:mt-52 lg:mt-60'
  aria-label='Introduction'>
  {
    name && (
      <header class='flex flex-col items-start gap-1'>
        <div class='flex items-center gap-2.5 md:gap-3'>
          {
            avatar && (
              <img
                src={avatar}
                alt={name ? `${name} avatar` : 'Avatar'}
                width='40'
                height='40'
                decoding='async'
                loading='eager'
                class='size-11 shrink-0 rounded-full object-cover md:size-10'
              />
            )
          }
          <p class='text-lg font-normal leading-snug text-zinc-900 dark:text-zinc-100 md:text-xl'>
            {name}
          </p>
        </div>
      </header>
    )
  }
  {
    !name && avatar && (
      <img
        src={avatar}
        alt='Avatar'
        width='40'
        height='40'
        decoding='async'
        loading='eager'
        class='size-11 shrink-0 rounded-full object-cover md:size-10'
      />
    )
  }
  <h1
    class:list={[
      'max-w-4xl whitespace-pre-line text-left font-medium tracking-tight text-zinc-900 dark:text-zinc-100',
      'leading-snug md:leading-snug lg:leading-[1.12]',
      'text-3xl sm:text-4xl md:text-5xl lg:text-[4rem]',
      'mt-4',
    ]}>
    {intro}
  </h1>
</section>
