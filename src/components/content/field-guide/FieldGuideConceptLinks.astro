---
/**
 * Quiet editorial links from journal/project pages into Field Guide entries.
 */
import Text from '../../ui/text/Text.astro'
import { type ConceptSummary } from '../../../lib/sanity'
import {
  cardLinkAnchorClass,
  cardLinkTitleUnderlineClass,
  linkListMutedContinuationClass,
} from '../../ui/text/styles'

interface Props {
  concepts: ConceptSummary[]
  /** Section overline (overline styles; visually uppercase). */
  heading?: string
  /** `measure`: centered 65ch (journal). `full`: span main content width (e.g. project case studies). */
  layout?: 'measure' | 'full'
}

const { concepts, heading = 'Field guide', layout = 'measure' } = Astro.props
const items = concepts.filter((c) => c?.slug?.current)
const widthClass = layout === 'full' ? 'w-full' : 'w-full max-w-[65ch] mx-auto'
---

{
  items.length > 0 && (
    <section
      class={`not-prose mt-16 border-t border-zinc-200 pt-12 dark:border-zinc-800 ${widthClass}`}
      aria-labelledby='fg-from-context-heading'>
      <Text variant='overline' color='muted' class='mb-8' id='fg-from-context-heading'>
        {heading}
      </Text>
      <ul class='m-0 list-none space-y-6 p-0'>
        {items.map((c) => (
          <li>
            <a href={`/field-guide/${c.slug!.current}`} class={cardLinkAnchorClass} data-swup-preload>
              <Text variant='h4' weight='medium' color='default' class={cardLinkTitleUnderlineClass}>
                {c.title}
              </Text>
              {c.summary && (
                <Text
                  variant='body'
                  color='muted'
                  class={`mt-2 max-w-[55ch] ${linkListMutedContinuationClass}`}>
                  {c.summary}
                </Text>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
