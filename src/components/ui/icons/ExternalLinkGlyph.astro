---
/**
 * Simple diagonal arrow (up-right) used as an external-link affordance.
 * Based on Heroicons `arrow-up-right` outline path.
 * Wrapper clips overflow so the glyph can slide off (up-right) and return from bottom-left on `group` hover/focus-visible.
 */
interface Props {
  /** Applied to the fixed-size clip box (width/height, alignment, colors). */
  class?: string
}

const { class: className } = Astro.props
---

<span
  class:list={['inline-flex shrink-0 items-center justify-center overflow-hidden', className]}
  aria-hidden='true'>
  <svg
    class:list={[
      'block h-full w-full',
      'motion-safe:group-hover:animate-link-icon-external-wrap motion-safe:group-focus-visible:animate-link-icon-external-wrap',
      'motion-reduce:group-hover:animate-none motion-reduce:group-focus-visible:animate-none',
    ]}
    fill='none'
    viewBox='0 0 24 24'
    stroke-width='2'
    stroke='currentColor'>
    <path
      stroke-linecap='round'
      stroke-linejoin='round'
      d='M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25'
    />
  </svg>
</span>
