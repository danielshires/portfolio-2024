---
/**
 * Heroicons outline “external link” path (same as react-icons `HiOutlineExternalLink` from `react-icons/hi`).
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class:list={['inline-block shrink-0', className]}
  fill='none'
  viewBox='0 0 24 24'
  stroke-width='2'
  stroke='currentColor'
  aria-hidden='true'>
  <path
    stroke-linecap='round'
    stroke-linejoin='round'
    d='M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14'
  />
</svg>
