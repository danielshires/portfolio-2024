---
/**
 * Simple diagonal arrow (up-right) used as an external-link affordance.
 * Based on Heroicons `arrow-up-right` outline path.
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class:list={['inline-block shrink-0', className]}
  fill='none'
  viewBox='0 0 24 24'
  stroke-width='2'
  stroke='currentColor'
  aria-hidden='true'>
  <path
    stroke-linecap='round'
    stroke-linejoin='round'
    d='M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25'
  />
</svg>
