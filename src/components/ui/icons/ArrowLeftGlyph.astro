---
/**
 * Heroicons `arrow-left` outline (24×24), stroke matched to {@link ExternalLinkGlyph}.
 * Wrapper clips overflow so the glyph can slide off left and re-enter from the right on `group` hover/focus-visible.
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<span
  class:list={['inline-flex shrink-0 items-center justify-center overflow-hidden', className]}
  aria-hidden='true'>
  <svg
    class:list={[
      'block h-full w-full',
      'motion-safe:group-hover:animate-link-icon-left-wrap motion-safe:group-focus-visible:animate-link-icon-left-wrap',
      'motion-reduce:group-hover:animate-none motion-reduce:group-focus-visible:animate-none',
    ]}
    fill='none'
    viewBox='0 0 24 24'
    stroke-width='2'
    stroke='currentColor'>
    <path
      stroke-linecap='round'
      stroke-linejoin='round'
      d='M10.5 19.5L3 12M3 12L10.5 4.5M3 12H21'
    />
  </svg>
</span>
