---
/**
 * Heroicons `arrow-left` outline (24×24), stroke matched to {@link ExternalLinkGlyph}.
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class:list={['inline-block shrink-0', className]}
  fill='none'
  viewBox='0 0 24 24'
  stroke-width='2'
  stroke='currentColor'
  aria-hidden='true'>
  <path
    stroke-linecap='round'
    stroke-linejoin='round'
    d='M10.5 19.5L3 12M3 12L10.5 4.5M3 12H21'
  />
</svg>
