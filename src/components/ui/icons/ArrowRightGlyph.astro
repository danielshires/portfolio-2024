---
/**
 * Heroicons `arrow-right` outline (24×24), stroke matched to {@link ExternalLinkGlyph}.
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class:list={['inline-block shrink-0', className]}
  fill='none'
  viewBox='0 0 24 24'
  stroke-width='2'
  stroke='currentColor'
  aria-hidden='true'>
  <path
    stroke-linecap='round'
    stroke-linejoin='round'
    d='M13.5 4.5L21 12M21 12L13.5 19.5M21 12H3'
  />
</svg>
