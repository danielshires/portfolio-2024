---
import { navLinkActiveClass, navLinkInactiveClass } from '../text/styles'

const pathname = new URL(Astro.request.url).pathname
const currentPath = pathname.slice(1)

interface Props {
  path: string
  target: string
  href: string
}

const { href, path, target } = Astro.props

const initialStyles =
  path === ''
    ? currentPath === ''
      ? navLinkActiveClass
      : navLinkInactiveClass
    : currentPath.startsWith(path)
      ? navLinkActiveClass
      : navLinkInactiveClass
---

<a
  class={initialStyles}
  href={href}
  target={target}
  data-swup-preload
  data-nav-path={path}
  data-nav-href={href}><slot /></a>
