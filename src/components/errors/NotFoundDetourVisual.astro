---
/**
 * Workbench-style monochrome sketch: soft contours + a dotted detour path.
 * Motion is ambient only; disabled when prefers-reduced-motion.
 */
---

<div
  class='not-found-detour-visual pointer-events-none mt-12 w-full max-w-2xl select-none md:mt-14'
  aria-hidden='true'>
  <svg
    class='w-full text-zinc-400/70 dark:text-zinc-600/80'
    viewBox='0 0 520 160'
    fill='none'
    xmlns='http://www.w3.org/2000/svg'>
    <path
      d='M0 112C48 108 72 124 120 118C168 112 192 90 240 96C288 102 312 128 360 124C408 120 432 98 480 94C502 92 514 96 520 98'
      stroke='currentColor'
      stroke-width='1'
      stroke-linecap='round'
      vector-effect='non-scaling-stroke'
      class='opacity-80'></path>
    <path
      d='M16 72C64 66 96 42 144 48C192 54 224 88 272 82C320 76 352 44 400 50C448 56 472 68 504 64'
      stroke='currentColor'
      stroke-width='1'
      stroke-linecap='round'
      vector-effect='non-scaling-stroke'
      class='opacity-50'></path>
    <path
      d='M32 40C72 34 112 22 152 28C192 34 216 52 256 46'
      stroke='currentColor'
      stroke-width='1'
      stroke-dasharray='3 6'
      stroke-linecap='round'
      vector-effect='non-scaling-stroke'
      class='opacity-40'></path>
    <path
      class='not-found-detour-path'
      d='M40 128C72 122 88 108 112 100C136 92 156 96 176 88C196 80 208 56 232 52C256 48 276 64 296 72C316 80 332 96 356 98C380 100 396 90 420 88C444 86 456 92 480 88'
      stroke='currentColor'
      stroke-width='1.25'
      stroke-dasharray='4 7'
      stroke-linecap='round'
      vector-effect='non-scaling-stroke'></path>
    <path
      d='M468 78L482 88L474 104'
      stroke='currentColor'
      stroke-width='1.25'
      stroke-linecap='round'
      stroke-linejoin='round'
      vector-effect='non-scaling-stroke'
      class='opacity-90'></path>
  </svg>
</div>

<style>
  @keyframes not-found-detour-dash {
    to {
      stroke-dashoffset: -120;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .not-found-detour-path {
      animation: not-found-detour-dash 14s linear infinite;
    }
  }
</style>
