---
import Layout from '../../layouts/Layout.astro'
import { getAllPosts, getPostBySlug, urlFor, type Post } from '../../lib/sanity'
import SanityImage from '../../components/media/images/SanityImage.astro'
import Text from '../../components/ui/text/Text.astro'
import ReadNext from '../../components/content/posts/ReadNext.astro'
import PortableTextImage from '../../components/content/posts/PortableTextImage.astro'
import { PortableText } from 'astro-portabletext'

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts
    .filter((post: Post) => post.slug?.current)
    .map((post: Post) => ({
      params: { slug: post.slug.current },
    }))
}

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/404')
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect('/404')
}

const readNextPosts =
  post.relatedPosts?.filter((p) => p && p._id !== post._id && p.slug?.current) ?? []

const seoImage = post.mainImage ? urlFor(post.mainImage).width(1200).height(630).url() : undefined

const portableTextComponents = {
  type: {
    image: PortableTextImage,
  },
}

const canonicalUrl = new URL(Astro.url.pathname, 'https://danielshires.com').href

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://danielshires.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Writing',
          item: 'https://danielshires.com/journal',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.title,
          item: canonicalUrl,
        },
      ],
    },
    {
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.description,
      url: canonicalUrl,
      datePublished: post.publishedAt,
      dateModified: post.publishedAt,
      author: {
        '@type': 'Person',
        name: post.author || 'Daniel Shires',
      },
      publisher: {
        '@type': 'Person',
        name: 'Daniel Shires',
      },
      image: seoImage ? [seoImage] : undefined,
      keywords: post.tags?.join(', '),
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    },
  ],
}
---

<Layout
  pageTitle={post.title}
  pageDescription={post.description}
  pageImage={seoImage}
  pageImageAlt={post.title}
  pageType='article'
  publishedTime={post.publishedAt}
  modifiedTime={post.publishedAt}
  jsonLd={jsonLd}>
  <div class='min-h-screen py-16 lg:py-24'>
    <article class='prose dark:prose-invert max-w-[75ch] mx-auto text-base'>
      <header class='text-center mt-12 mb-12'>
        <Text variant='h1' class='mb-2'>{post.title} </Text>
        {
          post.description && (
            <Text variant='h4' color='muted' class='mt-0 mb-1'>
              {post.description}
            </Text>
          )
        }
        <div class='mt-0 flex gap-2 items-center text-sm text-zinc-500 dark:text-zinc-400'>
          {
            post.author && (
              <Text variant='overline' color='muted'>
                By {post.author}
              </Text>
            )
          } ·
          {
            post.publishedAt && (
              <Text variant='overline' color='muted'>
                {new Date(post.publishedAt).toLocaleDateString(undefined, {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                })}
              </Text>
            )
          }
          {
            post.readingTime && (
              <Text variant='overline' color='muted'>
                {post.readingTime} min read
              </Text>
            )
          }
        </div>
      </header>
      {
        post.mainImage && (
          <div class='mb-12'>
            <SanityImage
              image={post.mainImage}
              alt={post.title}
              width={1200}
              height={800}
              preset='hero'
              class='w-full h-auto rounded-lg'
              sizes='(min-width: 1200px) 1200px, 100vw'
            />
          </div>
        )
      }
      <div class='prose dark:prose-invert max-w-none text-base mt-12'>
        {post.body && <PortableText value={post.body} components={portableTextComponents} />}
      </div>
    </article>

    <ReadNext posts={readNextPosts} />

    <!-- Navigation Back -->
    <div class='mt-16 text-center col-span-full'>
      <a
        href='/journal'
        class='inline-flex items-center text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors'>
        <svg class='w-4 h-4 mr-2' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M10 19l-7-7m0 0l7-7m-7 7h18'></path>
        </svg>
        <Text variant='body' color='muted'>Back to Writing</Text>
      </a>
    </div>
  </div>
</Layout>
