---
import Layout from '../../layouts/Layout.astro'
import { getAllPosts, getPostBySlug, urlFor, type Post } from '../../lib/sanity'
import SanityImage from '../../components/media/images/SanityImage.astro'
import Text from '../../components/ui/text/Text.astro'
import ReadNext from '../../components/content/posts/ReadNext.astro'
import FieldGuideConceptLinks from '../../components/content/field-guide/FieldGuideConceptLinks.astro'
import PortableTextImage from '../../components/content/posts/PortableTextImage.astro'
import { PortableText } from 'astro-portabletext'
import { PERSON_NODE_ID } from '../../lib/seo/merge-global-jsonld'

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts
    .filter((post: Post) => post.slug?.current)
    .map((post: Post) => ({
      params: { slug: post.slug.current },
    }))
}

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/404')
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect('/404')
}

const readNextPosts =
  post.relatedPosts?.filter((p) => p && p._id !== post._id && p.slug?.current) ?? []

const resolvedTitle = post.seo?.title?.trim() || post.title
const resolvedDescription = post.seo?.description?.trim() || post.description
const seoImage = post.mainImage ? urlFor(post.mainImage).width(1200).height(630).url() : undefined
const seoImageResolved = post.seo?.ogImage
  ? urlFor(post.seo.ogImage).width(1200).height(630).url()
  : seoImage
const resolvedRobots = post.seo?.noIndex ? 'noindex,follow' : undefined

const portableTextComponents = {
  type: {
    image: PortableTextImage,
  },
}

const canonicalUrl = new URL(Astro.url.pathname, 'https://danielshires.com').href

const metaBits: string[] = []
if (post.author) metaBits.push(`By ${post.author}`)
if (post.publishedAt)
  metaBits.push(
    new Date(post.publishedAt).toLocaleDateString(undefined, {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  )
if (post.readingTime != null && post.readingTime !== '')
  metaBits.push(`${post.readingTime} min read`)

const metaAriaLabel = metaBits.length > 0 ? metaBits.join(', ') : undefined

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://danielshires.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Writing',
          item: 'https://danielshires.com/journal',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.title,
          item: canonicalUrl,
        },
      ],
    },
    {
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.description,
      url: canonicalUrl,
      datePublished: post.publishedAt,
      dateModified: post.publishedAt,
      author: post.author
        ? {
            '@type': 'Person',
            name: post.author,
          }
        : {
            '@id': PERSON_NODE_ID,
          },
      publisher: {
        '@id': PERSON_NODE_ID,
      },
      image: seoImageResolved ? [seoImageResolved] : undefined,
      keywords: post.tags?.join(', '),
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    },
  ],
}
---

<Layout
  pageTitle={resolvedTitle}
  pageDescription={resolvedDescription}
  pageImage={seoImageResolved}
  pageImageAlt={post.title}
  pageType='article'
  publishedTime={post.publishedAt}
  modifiedTime={post.publishedAt}
  robots={resolvedRobots}
  jsonLd={jsonLd}>
  <div class='min-h-screen py-16 lg:py-24'>
    <article class='prose dark:prose-invert prose-headings:text-left max-w-[65ch] mx-auto text-base'>
      <header class='not-prose text-left mt-12 mb-12 flex flex-col gap-5 md:gap-6'>
        <Text variant='h1'>{post.title}</Text>
        {
          post.description && (
            <Text variant='lead' color='muted' class='max-w-[55ch]'>
              {post.description}
            </Text>
          )
        }
        {
          metaBits.length > 0 && (
            <Text variant='overline' color='muted' aria-label={metaAriaLabel}>
              {metaBits.join(' · ')}
            </Text>
          )
        }
      </header>
      {
        post.mainImage && (
          <div class='not-prose mb-12'>
            <SanityImage
              image={post.mainImage}
              alt={post.title}
              width={1200}
              height={800}
              preset='hero'
              class='w-full h-auto rounded-lg'
              sizes='(min-width: 1200px) 1200px, 100vw'
            />
          </div>
        )
      }
      {post.body && (
        <div class='mt-12'>
          <PortableText value={post.body} components={portableTextComponents} />
        </div>
      )}
    </article>

    <FieldGuideConceptLinks concepts={post.conceptsDiscussed ?? []} />

    <ReadNext posts={readNextPosts} />

    <section class='not-prose max-w-[65ch] mx-auto mt-16 border-t border-zinc-200/80 pt-12 dark:border-zinc-800/80' aria-label='Design work'>
      <Text variant='h3' class='mb-3'>Design work</Text>
      <Text variant='body' color='muted'>
        Case studies and portfolio —{' '}
        <a
          href='/projects'
          class='text-zinc-900 underline decoration-zinc-400 underline-offset-4 transition-colors hover:decoration-zinc-900 dark:text-zinc-100 dark:decoration-zinc-600 dark:hover:decoration-zinc-100'>
          Browse projects
        </a>{' '}
        or{' '}
        <a
          href='/design'
          class='text-zinc-900 underline decoration-zinc-400 underline-offset-4 transition-colors hover:decoration-zinc-900 dark:text-zinc-100 dark:decoration-zinc-600 dark:hover:decoration-zinc-100'>
          see the design index
        </a>
        .
      </Text>
    </section>
  </div>
</Layout>
