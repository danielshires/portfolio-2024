---
import Layout from '../../layouts/Layout.astro'
import { getAllPosts, getPostBySlug, urlFor, type Post } from '../../lib/sanity'
import SanityImage from '../../components/media/images/SanityImage.astro'
import Text from '../../components/ui/text/Text.astro'
import ReadNext from '../../components/content/posts/ReadNext.astro'
import PortableTextImage from '../../components/content/posts/PortableTextImage.astro'
import { PortableText } from 'astro-portabletext'

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts
    .filter((post: Post) => post.slug?.current)
    .map((post: Post) => ({
      params: { slug: post.slug.current },
    }))
}

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/404')
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect('/404')
}

const readNextPosts =
  post.relatedPosts?.filter((p) => p && p._id !== post._id && p.slug?.current) ?? []

const seoImage = post.mainImage ? urlFor(post.mainImage).width(1200).height(630).url() : undefined

const portableTextComponents = {
  type: {
    image: PortableTextImage,
  },
}

const canonicalUrl = new URL(Astro.url.pathname, 'https://danielshires.com').href

const metaBits: string[] = []
if (post.author) metaBits.push(`By ${post.author}`)
if (post.publishedAt)
  metaBits.push(
    new Date(post.publishedAt).toLocaleDateString(undefined, {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  )
if (post.readingTime != null && post.readingTime !== '')
  metaBits.push(`${post.readingTime} min read`)

const metaAriaLabel = metaBits.length > 0 ? metaBits.join(', ') : undefined

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://danielshires.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Writing',
          item: 'https://danielshires.com/journal',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.title,
          item: canonicalUrl,
        },
      ],
    },
    {
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.description,
      url: canonicalUrl,
      datePublished: post.publishedAt,
      dateModified: post.publishedAt,
      author: {
        '@type': 'Person',
        name: post.author || 'Daniel Shires',
      },
      publisher: {
        '@type': 'Person',
        name: 'Daniel Shires',
      },
      image: seoImage ? [seoImage] : undefined,
      keywords: post.tags?.join(', '),
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    },
  ],
}
---

<Layout
  pageTitle={post.title}
  pageDescription={post.description}
  pageImage={seoImage}
  pageImageAlt={post.title}
  pageType='article'
  publishedTime={post.publishedAt}
  modifiedTime={post.publishedAt}
  jsonLd={jsonLd}>
  <div class='min-h-screen py-16 lg:py-24'>
    <article class='prose dark:prose-invert prose-headings:text-left max-w-[65ch] mx-auto text-base'>
      <header class='not-prose text-left mt-12 mb-12 flex flex-col gap-5 md:gap-6'>
        <Text variant='h1'>{post.title}</Text>
        {
          post.description && (
            <Text variant='lead' color='muted' class='max-w-[55ch]'>
              {post.description}
            </Text>
          )
        }
        {
          metaBits.length > 0 && (
            <Text variant='overline' color='muted' aria-label={metaAriaLabel}>
              {metaBits.join(' · ')}
            </Text>
          )
        }
      </header>
      {
        post.mainImage && (
          <div class='not-prose mb-12'>
            <SanityImage
              image={post.mainImage}
              alt={post.title}
              width={1200}
              height={800}
              preset='hero'
              class='w-full h-auto rounded-lg'
              sizes='(min-width: 1200px) 1200px, 100vw'
            />
          </div>
        )
      }
      {post.body && (
        <div class='mt-12'>
          <PortableText value={post.body} components={portableTextComponents} />
        </div>
      )}
    </article>

    <ReadNext posts={readNextPosts} />
  </div>
</Layout>
