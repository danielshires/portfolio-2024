---
import Layout from '../../layouts/Layout.astro'
import { getAllProjects, urlFor, projectListHref, isExternalProject } from '../../lib/sanity'
import Text from '../../components/ui/text/Text.astro'
import SimpleHero from '../../components/content/featured/SimpleHero.astro'
import ProjectCard from '../../components/content/projects/ProjectCard.astro'

const projects = await getAllProjects()

const pageTitle = 'Projects | Daniel Shires'
const pageDescription =
  'Explore my latest design and development projects, featuring UI/UX design, web development, and digital experiences.'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Projects',
  description: pageDescription,
  url: 'https://danielshires.com/projects',
  author: {
    '@type': 'Person',
    name: 'Daniel Shires',
    jobTitle: 'Product Designer',
  },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: projects.length,
    itemListElement: projects.slice(0, 10).map((project, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'CreativeWork',
        name: project.title,
        description: project.subtitle || 'Design project by Daniel Shires',
        url: isExternalProject(project)
          ? project.externalUrl!.trim()
          : `https://danielshires.com/projects/${project.slug.current}`,
        creator: {
          '@type': 'Person',
          name: 'Daniel Shires',
        },
        dateCreated: project.publishedAt,
        keywords: project.tags?.join(', ') || 'UX Design, UI Design, Product Design',
      },
    })),
  },
}
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} jsonLd={structuredData}>
  <!-- Hero Section -->
  <SimpleHero
    introText={{
      first: 'Projects',
      second:
        'A collection of my design and development work, showcasing solutions to real-world problems.',
    }}
  />

  <!-- Projects Grid -->
  <section class='my-16 md:my-24'>
      {
        projects.length > 0 ? (
          <div class='grid grid-cols-1 md:grid-cols-3 gap-8 overflow-hidden'>
            {projects.map((project) => {
              // Prepare image props
              let projectImage
              if (project.heroImage) {
                projectImage = {
                  src: urlFor(project.heroImage)
                    .width(800)
                    .height(533)
                    .quality(85) // Standard quality for project thumbnails
                    .auto('format')
                    .fit('max')
                    .url(),
                  alt: project.title || 'Project image',
                  width: 800,
                  height: 533,
                }
              } else {
                projectImage = {
                  src: '',
                  alt: 'No image',
                  width: 800,
                  height: 533,
                }
              }
              return (
                <ProjectCard
                  projectImage={projectImage}
                  title={project.title}
                  heading={project.subtitle}
                  projectUrl={projectListHref(project)}
                  external={isExternalProject(project)}
                />
              )
            })}
          </div>
        ) : (
          <div class='text-center py-16'>
            <Text variant='h3' class='mb-2'>
              No projects yet
            </Text>
            <Text variant='body' color='muted'>
              Check back soon for new content.
            </Text>
          </div>
        )
      }
  </section>
</Layout>
