---
import Layout from '../../layouts/Layout.astro'
import { getProjectBySlug, getAllProjects, urlFor } from '../../lib/sanity'
import ProjectMeta from '../../components/content/projects/ProjectMeta.astro'
import ProjectOutcomes from '../../components/content/projects/ProjectOutcomes.astro'
import ProjectProblem from '../../components/content/projects/ProjectProblem.astro'
import RelatedProjects from '../../components/content/projects/RelatedProjects.astro'
import FieldGuideConceptLinks from '../../components/content/field-guide/FieldGuideConceptLinks.astro'
import SiteChildNav from '../../components/layout/navigation/SiteChildNav.astro'
import Text from '../../components/ui/text/Text.astro'
import { PERSON_NODE_ID } from '../../lib/seo/merge-global-jsonld'

// Generate static paths for internal case-study pages only (link-out projects have no /projects/[slug] page).
export async function getStaticPaths() {
  const projects = await getAllProjects()
  return projects
    .filter((project) => project.slug?.current && project.linkBehavior !== 'external')
    .map((project) => ({
      params: { slug: project.slug.current },
      props: { project },
    }))
}

const { project: _ } = Astro.props
const { slug } = Astro.params

// Redirect to 404 if no slug provided
if (!slug) {
  return Astro.redirect('/404')
}

// Fetch complete project data with all fields
const fullProject = await getProjectBySlug(slug)

// Redirect to 404 if project not found
if (!fullProject) {
  return Astro.redirect('/404')
}

// Prepare SEO metadata
const seoTitleBase = fullProject.title + (fullProject.client ? ` | ${fullProject.client}` : '')
const seoTitle = fullProject.seo?.title?.trim() || seoTitleBase
const seoDescription =
  fullProject.seo?.description?.trim() ||
  fullProject.subtitle ||
  `${fullProject.title} project case study`
const seoImage = fullProject.heroImage
  ? urlFor(fullProject.heroImage).width(1200).height(630).url()
  : undefined
const seoImageResolved = fullProject.seo?.ogImage
  ? urlFor(fullProject.seo.ogImage).width(1200).height(630).url()
  : seoImage
const resolvedRobots = fullProject.seo?.noIndex ? 'noindex,follow' : undefined

const canonicalUrl = new URL(Astro.url.pathname, 'https://danielshires.com').href

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://danielshires.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Projects',
          item: 'https://danielshires.com/projects',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: fullProject.title,
          item: canonicalUrl,
        },
      ],
    },
    {
      '@type': 'CreativeWork',
      name: fullProject.title,
      headline: fullProject.title,
      description: seoDescription,
      url: canonicalUrl,
      datePublished: fullProject.publishedAt,
      dateModified: fullProject.publishedAt,
      author: {
        '@id': PERSON_NODE_ID,
      },
      creator: {
        '@id': PERSON_NODE_ID,
      },
      keywords: fullProject.tags?.join(', '),
      image:
        fullProject.images?.map((image) =>
          urlFor(image.asset).width(2000).auto('format').url()
        ) || (seoImageResolved ? [seoImageResolved] : undefined),
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    },
  ],
}
---

<Layout
  pageTitle={seoTitle}
  pageDescription={seoDescription}
  pageImage={seoImageResolved}
  pageType='article'
  publishedTime={fullProject.publishedAt}
  modifiedTime={fullProject.publishedAt}
  robots={resolvedRobots}
  jsonLd={jsonLd}>
  <!-- Project Header Section -->
  <section
    class='grid grid-cols-1 lg:grid-cols-2 items-center mt-40 mb-20 md:pt-32 md:mb-40'>
    <!-- Left Column: Project Title, Subtitle, and Metadata -->
    <div class='grid grid-cols-1 lg:grid-cols-2 col-span-1 md:col-span-2 gap-16'>
      <div class='lg:col-span-1'>
        <Text variant='h1' class='mb-2'>{fullProject.title}</Text>
        <Text variant='h2' color='muted' class='mb-8'>{fullProject.subtitle}</Text>
        <ProjectMeta
          client={fullProject.client}
          role={fullProject.role}
          team={fullProject.team}
          year={fullProject.publishedAt ? new Date(fullProject.publishedAt).getFullYear() : undefined}
        />
      </div>

      <!-- Right Column: Problem Statement and Outcomes -->
      <div class='lg:col-span-1'>
        <!-- Problem Statement -->
        {fullProject.problem && <ProjectProblem problem={fullProject.problem} />}

        <!-- Project Outcomes -->
        {
          fullProject.outcomes && fullProject.outcomes.length > 0 && (
            <div class='lg:col-span-1'>
              <ProjectOutcomes outcomes={fullProject.outcomes} />
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Project Gallery Section -->
  {
    fullProject.images && fullProject.images.length > 0 && (
      <section class='col-span-full'>
        <div class='space-y-8'>
          {fullProject.images.map((image) => (
            <div class='space-y-4 w-full aspect-[3/2] rounded-xl'>
              <img
                src={urlFor(image.asset)
                  .width(3840)
                  .quality(90) // High quality for detailed project images
                  .auto('format')
                  .fit('max')
                  .url()}
                alt={image.alt}
                class='w-full'
                loading='lazy'
              />
              {image.caption && (
                <Text variant='caption' color='muted' class='text-center'>
                  {image.caption}
                </Text>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Related Projects Section -->
  {
    fullProject.relatedProjects && fullProject.relatedProjects.length > 0 && (
      <section class='my-20'>
        <RelatedProjects projects={fullProject.relatedProjects} />
      </section>
    )
  }

  <FieldGuideConceptLinks concepts={fullProject.conceptsDemonstrated ?? []} heading='Concepts demonstrated' layout='full' />

  <SiteChildNav parentHref='/projects' parentLabel='Projects' layout='full' />
</Layout>
