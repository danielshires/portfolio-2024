---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/content/featured/Hero.astro'
import WritingPreview from '../components/content/posts/WritingPreview.astro'
import ProjectGrid from '../components/content/projects/ProjectGrid.astro'
import { getAuthorBySlug, getAllProjects, getFeaturedProjects, getAllPosts, urlFor } from '../lib/sanity'

const author = await getAuthorBySlug('daniel-shires')
const avatarUrl = author?.image ? urlFor(author.image).width(192).height(192).url() : undefined

const heroContent = {
  name: '',
  intro: `Hi, I'm Dan — a Product Designer with 5+ years experience designing cohesive, user-centered digital products.`,
  avatar: avatarUrl,
}

// Writing (posts) for homepage preview
const allPosts = await getAllPosts()

// Get projects from Sanity
const allProjects = await getAllProjects()
const featuredProjects = await getFeaturedProjects()

// Use featured projects if available, otherwise show first 6 regular projects
const projectsToShow =
  featuredProjects.length > 0 ? featuredProjects.slice(0, 6) : allProjects.slice(0, 6)

// SEO optimized content
const pageTitle = 'Daniel Shires | Product Designer | Sydney, Australia'
const pageDescription =
  'Product Designer with 5+ years experience creating user-centered digital experiences. Based in Sydney, working at Commonwealth Bank. View my design portfolio and writing.'
const pageImage = avatarUrl || '/images/jpg/background.webp'

// Structured data for the homepage
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Daniel Shires',
  jobTitle: 'Product Designer',
  url: 'https://danielshires.com',
  image: pageImage,
  description: pageDescription,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sydney',
    addressCountry: 'AU',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'Commonwealth Bank',
  },
  knowsAbout: [
    'UX Design',
    'UI Design',
    'Product Design',
    'Photography',
    'Front-end Development',
    'Human Centered Design',
  ],
  sameAs: ['https://linkedin.com/in/danielshires', 'https://twitter.com/danielshires'],
}
---

<Layout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  pageImage={pageImage}
  jsonLd={structuredData}
  pageType='website'>
  <main class='grid gap-8 overflow-hidden h-max pb-16 md:pb-24'>
    <Hero {...heroContent} />
    <WritingPreview posts={allPosts} />
    <div class='mt-auto'>
      <ProjectGrid projects={projectsToShow} variant='text' />
    </div>
  </main>
</Layout>
