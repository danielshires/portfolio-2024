---
import Layout from '../layouts/Layout.astro'
import Text from '../components/ui/text/Text.astro'
import {
  contentSectionHeadingArrowClass,
  contentSectionHeadingLinkClass,
  externalLinkGlyphGroupHoverClass,
  sectionYearLabelClass,
  simpleHeroSectionClass,
  textLinkClass,
} from '../components/ui/text/styles'
import ArrowRightGlyph from '../components/ui/icons/ArrowRightGlyph.astro'
import ExternalLinkGlyph from '../components/ui/icons/ExternalLinkGlyph.astro'
import { aboutContent } from '../config/about'
import {
  getAllProjects,
  projectListHref,
  isExternalProject,
  urlFor,
} from '../lib/sanity'

const projects = await getAllProjects()

const pageTitle = 'About | Daniel Shires'
const pageDescription =
  'Product designer in Sydney at Commonwealth Bank. Work history, case studies, and ways to connect.'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: pageTitle,
  description: pageDescription,
  url: 'https://danielshires.com/about',
  mainEntity: {
    '@type': 'Person',
    name: 'Daniel Shires',
    jobTitle: 'Senior Product Designer',
    url: 'https://danielshires.com',
    sameAs: aboutContent.social.map((s) => s.href).filter((h) => h.startsWith('http')),
  },
}
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} jsonLd={structuredData}>
  <article class='pb-16 md:pb-24'>
    <header class={simpleHeroSectionClass} aria-label='About'>
      <Text variant='h1'>About</Text>
    </header>

    <section class='mt-10 md:mt-14 max-w-3xl' aria-label='Summary'>
      <div class='space-y-4'>
        <Text variant='body' class='!text-xl !leading-relaxed md:!text-[2rem] md:!leading-snug'>
          {aboutContent.summary.paragraph1BeforeLink}
          <a
            href={aboutContent.summary.paragraph1Link.href}
            target='_blank'
            rel='noopener noreferrer'
            class={`text-zinc-900 dark:text-zinc-100 ${textLinkClass}`}>
            {aboutContent.summary.paragraph1Link.label}
          </a>
          {aboutContent.summary.paragraph1AfterLink}
        </Text>
        <Text variant='body' class='!text-xl !leading-relaxed md:!text-[2rem] md:!leading-snug'>
          {aboutContent.summary.paragraph2}
        </Text>
      </div>
    </section>

    <section class='mt-14 md:mt-20' aria-label='Social links'>
      <Text variant='caption' color='muted' class='mb-4 font-mono text-xs uppercase tracking-wider'>
        Connect
      </Text>
      <ul class='flex flex-wrap gap-x-6 gap-y-2'>
        {
          aboutContent.social.map((link) => (
            <li>
              <a
                href={link.href}
                class={`text-base text-zinc-900 dark:text-zinc-100 ${textLinkClass}`}
                target={link.href.startsWith('mailto:') ? undefined : '_blank'}
                rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class='mt-14 md:mt-20' aria-label='Work history'>
      <Text variant='caption' color='muted' class='mb-4 font-mono text-xs uppercase tracking-wider'>
        Work
      </Text>
      <ul class='divide-y divide-zinc-200/60 dark:divide-zinc-800/60'>
        {
          aboutContent.work.map((entry) => (
            <li class='flex flex-col gap-1 py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6'>
              <div class='min-w-0'>
                {entry.organizationHref ? (
                  <a
                    href={entry.organizationHref}
                    target='_blank'
                    rel='noopener noreferrer'
                    class={`font-medium text-zinc-900 dark:text-zinc-100 ${textLinkClass}`}>
                    {entry.organization}
                  </a>
                ) : (
                  <span class='font-medium text-zinc-900 dark:text-zinc-100'>{entry.organization}</span>
                )}
                <span class='text-zinc-600 before:mx-1.5 before:content-["·"] dark:text-zinc-400'>
                  {entry.role}
                </span>
              </div>
              <span class='shrink-0 text-sm tabular-nums text-zinc-600 dark:text-zinc-400'>
                {entry.period}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class='mt-14 md:mt-20' aria-label='Projects'>
      <h2 class={sectionYearLabelClass}>
        <a href='/projects' class={contentSectionHeadingLinkClass}>
          Projects
          <ArrowRightGlyph class={contentSectionHeadingArrowClass} />
        </a>
      </h2>
      {
        projects.length > 0 ? (
          <ul class='divide-y divide-zinc-200/60 dark:divide-zinc-800/60'>
            {projects.map((project) => {
              const href = projectListHref(project)
              const external = isExternalProject(project)
              const thumb =
                project.heroImage != null
                  ? urlFor(project.heroImage).width(128).height(128).auto('format').fit('max').url()
                  : null
              return (
                <li>
                  <a
                    href={href}
                    class='group flex items-start gap-4 py-6 transition-colors'
                    target={external ? '_blank' : undefined}
                    rel={external ? 'noopener noreferrer' : undefined}
              {...(!external ? { 'data-swup-preload': true } : {})}>
                    {thumb && (
                      <img
                        src={thumb}
                        alt=''
                        width='48'
                        height='48'
                        class='size-[3rem] shrink-0 self-start rounded-md object-cover'
                        loading='lazy'
                        decoding='async'
                      />
                    )}
                    <div class='min-w-0 flex-1'>
                      <div class='flex flex-wrap items-center gap-x-1 gap-y-0.5'>
                        <span class='font-medium text-zinc-900 no-underline decoration-zinc-400 underline-offset-4 transition-colors group-hover:underline group-hover:decoration-zinc-900 dark:text-zinc-100 dark:decoration-zinc-600 dark:group-hover:decoration-zinc-100'>
                          {project.title}
                        </span>
                        {external && (
                          <ExternalLinkGlyph
                            class={`relative top-px h-[0.8em] w-[0.8em] shrink-0 self-center ${externalLinkGlyphGroupHoverClass}`}
                          />
                        )}
                      </div>
                      {project.subtitle && (
                        <p class='mt-1 text-sm leading-snug text-zinc-600 dark:text-zinc-400'>
                          {project.subtitle}
                        </p>
                      )}
                    </div>
                  </a>
                </li>
              )
            })}
          </ul>
        ) : (
          <Text variant='body' color='muted'>
            No projects published yet.
          </Text>
        )
      }
    </section>
  </article>
</Layout>
