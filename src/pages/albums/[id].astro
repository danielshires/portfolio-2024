---
import { getCollection } from "astro:content";
import Layout from '../../layouts/Layout.astro'

export async function getStaticPaths() {
  const albums = await getCollection("albums");

  const paths = Object.values(albums).map((album) => {
    return {
      params: {
        id: (album as any).id,
      },
      props: {
        album,
      },
    };
  });

  return paths;
}

const { album } = Astro.props;

const pageTitle = `${(album as any).data.title} (legacy)`
const pageDescription =
  (album as any).data.description || 'Legacy album page (not indexed).'
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} robots='noindex,follow'>
  <div class="text-center my-16 mb-32">
    <h1 class="text-3xl xl:text-6xl font-bold">
      {(album as any).data.title}
    </h1>
    <p class="text-base xl:text-2xl my-4">
      {(album as any).data.description}
    </p>

    <div>
      Images go here...
    </div>

    <p class="text-lg my-4 text-center">
      <a href="/pictures" class="hover:underline">Go back →</a>
    </p>
  </div>
</Layout>
